# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Banco de dados local (gerado em runtime) — contém PII de funcionários
*.db
*.sqlite
*.sqlite3
*.db.bak-*

# Snapshots de rollback locais
.rollback/

# Planilhas reais de cliente (PII) — só a doc do modelo vai pro git
docs/modelos/*.xlsx

# Variáveis de ambiente com segredos
.env

# Arquivos gerados pela aplicação
app/generated_reports/
app/excel_templates/
epi_documents/

# Assets de desenvolvimento / Replit
attached_assets/

# Logs
*.log
