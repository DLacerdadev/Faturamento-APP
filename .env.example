# ─── Banco de Dados Principal ────────────────────────────────────────────────
# PostgreSQL para produção. Deixe vazio para usar SQLite (desenvolvimento).
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# ─── Senior ERP – SQL Server (MSSQL) ─────────────────────────────────────────
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DB=
MSSQL_USER=
MSSQL_PASS=
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ─── Senior – API REST ────────────────────────────────────────────────────────
DOMAIN_API=
API_KEY=

# ─── Senior – Serviços SOAP ──────────────────────────────────────────────────
SENIOR_SOAP_URL=https://webp33.seniorcloud.com.br:30721/g5-senior-services/rubi_Synccom_opus_fopag?wsdl
SENIOR_SOAP_NEXTI_URL=https://webp33.seniorcloud.com.br:30721/g5-senior-services/rubi_Synccom_opus_nexti
SENIOR_SOAP_USER=
SENIOR_SOAP_PASSWORD=
SENIOR_SOAP_TOKEN=
SENIOR_SOAP_ENCRYPTION=0

# ─── SMTP (opcional, feature 002 — envio de solicitação de compra por email) ─
# Se SMTP_HOST estiver vazio, a UI esmaece o botão "Enviar por email" e mantém
# apenas o download do Excel. Preencher tudo para ativar o envio.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@grupoopus.com
SMTP_USE_TLS=1

# Destinatário padrão das solicitações de compra de EPI (editável no envio).
EPI_PURCHASE_EMAIL=compras@grupoopus.com

# ─── Cache e Throttle das Chamadas Senior (feature 003) ─────────────────────
# TTL em segundos. Lazy expiration: entrada expirada é descartada na próxima leitura.
# CCU (T018CCU) — quase estático; default 6h.
SENIOR_CACHE_CCU_TTL=21600
# Funcionários ativos por CCU+mês corrente; default 1h.
SENIOR_CACHE_EMPLOYEES_TTL=3600
# Máximo de chamadas SOAP simultâneas (semáforo bloqueante). Default 3.
SENIOR_SOAP_MAX_CONCURRENCY=3
